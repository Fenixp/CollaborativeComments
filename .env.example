# Local development defaults
APP_PORT=3000
APP_ORIGIN=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000

CONVEX_PORT=3210
CONVEX_SITE_PORT=3211
CONVEX_DASHBOARD_PORT=6791
PUBLIC_CONVEX_URL=http://localhost:3210
PUBLIC_CONVEX_SITE_URL=http://localhost:3211

# Replace before any shared or hosted deployment.
CONVEX_INSTANCE_NAME=collaborative-comments
# Must be an even-length hex string.
CONVEX_INSTANCE_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Clerk browser key for the SvelteKit shell.
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Clerk frontend API / issuer domain for Convex token validation.
CLERK_JWT_ISSUER_DOMAIN=https://example.clerk.accounts.dev

# Self-hosted Convex CLI access after you generate an admin key from the backend container.
CONVEX_SELF_HOSTED_URL=http://localhost:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=replace-after-running-generate_admin_key.sh

# Keep local self-hosting simple unless a proxy or TLS terminator is in front.
DO_NOT_REQUIRE_SSL=true
DISABLE_BEACON=true
DISABLE_METRICS_ENDPOINT=true
RUST_LOG=info
